{
  "name": "@omnsight/osint-entity-components",
  "publishConfig": {
    "access": "public"
  },
  "version": "0.2.7",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/omnsight/omni-osint-entity-components.git",
    "directory": "client"
  },
  "engines": {
    "node": ">=24.0.0"
  },
  "type": "module",
  "files": [
    "dist",
    "src"
  ],
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "require": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./avatars": {
      "import": "./src/avatars/index.ts",
      "types": "./src/avatars/index.ts"
    },
    "./cards": {
      "import": "./src/cards/index.ts",
      "types": "./src/cards/index.ts"
    },
    "./forms": {
      "import": "./src/forms/index.ts",
      "types": "./src/forms/index.ts"
    },
    "./icons": {
      "import": "./src/icons/index.ts",
      "types": "./src/icons/index.ts"
    },
    "./inputs": {
      "import": "./src/inputs/index.ts",
      "types": "./src/inputs/index.ts"
    },
    "./locales/en": {
      "import": "./src/locales/en.json"
    },
    "./locales/zh": {
      "import": "./src/locales/zh.json"
    }
  },
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "sync": "node scripts/sync-icons.mjs",
    "preview": "vite preview",
    "clean": "rm -rf node_modules package-lock.json dist"
  },
  "dependencies": {
    "@heroicons/react": "^2.2.0",
    "@mantine/core": "^8.3.18",
    "@mantine/dates": "^8.3.18",
    "@mantine/hooks": "^8.3.18",
    "@mantine/modals": "^8.3.18",
    "@mantine/notifications": "^8.3.18",
    "@svgr/plugin-jsx": "^8.1.0",
    "@svgr/plugin-svgo": "^8.1.0",
    "date-fns-tz": "^3.2.0",
    "i18n-iso-countries": "^7.14.0",
    "loadash": "^1.0.0",
    "omni-monitoring-client": "latest",
    "omni-osint-crud-client": "latest",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-hook-form": "^7.72.0",
    "react-i18next": "^16.6.6",
    "react-timezone-select": "^3.3.3"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@iconify/utils": "^3.1.0",
    "@svgr/core": "^8.1.0",
    "@types/lodash": "^4.17.24",
    "@types/node": "^24.12.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "glob": "^13.0.6",
    "globals": "^17.4.0",
    "postcss": "^8.5.6",
    "postcss-preset-mantine": "^1.18.0",
    "postcss-simple-vars": "^7.0.1",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.57.0",
    "vite": "^8.0.1",
    "vite-plugin-dts": "^4.5.4"
  }
}
